# AI Workflow Control Plane Environment Configuration

# PostgreSQL connection string (required)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_workflow

# Backend server port (default: 8000)
# PORT=8000

# Frontend bridge API URL.
# Dev default is http://localhost:8000. Production can leave this empty when nginx
# serves the frontend and proxies /api, /sse, and /ws to the backend.
VITE_API_BASE_URL=http://localhost:8000
VITE_WS_BASE_URL=ws://localhost:8000

# Environment mode: "development" or "production"
# In production, ENCRYPTION_KEY is required (app refuses to start without it).
# ENVIRONMENT=development

# Encryption key for connector secrets (Fernet symmetric encryption).
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# In development, a random key is auto-generated (secrets lost on restart).
# Docker Compose requires this value so connector webhook secrets survive restarts.
# ENCRYPTION_KEY=

# Test database (optional — used by pytest when set; tests skip PG tests if absent)
# TEST_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_workflow_test

# Webhook signature verification (per-connector, not global)
# Set "webhook_secret" in connector config_json to enable HMAC-SHA256 verification.
# Clients must send X-Webhook-Signature: sha256=<hex> header.
# Anti-replay: payload must include "timestamp" field; stale payloads (>300s) are rejected.

# Optional Notion integration token. Keep real values in local .env only.
NOTION_API_KEY=
