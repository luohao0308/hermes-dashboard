# Hermès Dashboard Environment Configuration

# Hermes Dashboard API URL (default: localhost:9119)
HERMES_API_URL=http://localhost:9119

# Backend server port (default: 8000)
# PORT=8000

# Chat persistence database path (default: backend/data/chat_sessions.sqlite3)
# CHAT_DB_PATH=backend/data/chat_sessions.sqlite3

# Frontend bridge API URL.
# Dev default is http://localhost:8000. Production can leave this empty when nginx
# serves the frontend and proxies /api, /sse, and /ws to the backend.
VITE_API_BASE_URL=http://localhost:8000
VITE_WS_BASE_URL=ws://localhost:8000

# Optional Notion integration token. Keep real values in local .env only.
NOTION_API_KEY=
